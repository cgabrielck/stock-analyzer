# OpenAI-compatible LLM provider. Never commit a real API key.
LLM_API_KEY=replace-with-a-new-key
LLM_BASE_URL=https://tbnx.plus7.plus/v1
LLM_MODEL=deepseek-chat
LLM_REASONING_MODEL=deepseek-reasoner

